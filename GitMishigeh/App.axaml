<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GitMishigeh.App"
             xmlns:local="using:GitMishigeh"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background" Value="#0B1020" />
            <Setter Property="Foreground" Value="#EEF2FF" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#11182B" />
            <Setter Property="BorderBrush" Value="#26324D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style Selector="Border.card.toolbar-shell">
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8FA2C9" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Background" Value="#17233A" />
            <Setter Property="BorderBrush" Value="#2A3B5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#20304D" />
            <Setter Property="BorderBrush" Value="#3A5689" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#0F1A2E" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7C3AED" />
            <Setter Property="BorderBrush" Value="#8B5CF6" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#8B5CF6" />
            <Setter Property="BorderBrush" Value="#A78BFA" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0E1526" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#29364F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Border.list-item">
            <Setter Property="Background" Value="#0D1424" />
            <Setter Property="BorderBrush" Value="#22304A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#16233A" />
            <Setter Property="BorderBrush" Value="#32486D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="TextBlock.badge-text">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#C7D2FE" />
        </Style>
        <Style Selector="ScrollViewer.list-scroll">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Application.Styles>
</Application>
