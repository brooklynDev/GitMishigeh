<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GitMishigeh.App"
             xmlns:local="using:GitMishigeh"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <Style Selector="Window">
            <Setter Property="Background" Value="#0B1019" />
            <Setter Property="Foreground" Value="#E6EBF4" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#222C3E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="Border.card.toolbar-shell">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#23304A" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7D8CA5" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#94A3B8" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="#1B2537" />
            <Setter Property="BorderBrush" Value="#2B3A57" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E5EAF3" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#243149" />
            <Setter Property="BorderBrush" Value="#446089" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#162133" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.42" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#3B82F6" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
        </Style>
        <Style Selector="Button.subtle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#2B3A57" />
            <Setter Property="Foreground" Value="#A7B3C7" />
        </Style>
        <Style Selector="CheckBox.file-selector">
            <Setter Property="Foreground" Value="#93C5FD" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E5EAF3" />
            <Setter Property="BorderBrush" Value="#29364B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="38" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Border.list-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.list-item">
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock.list-title">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock.subtle">
            <Setter Property="Foreground" Value="#D6E4FF" />
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock.badge-text">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock.muted">
            <Setter Property="Foreground" Value="#D6E4FF" />
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#132238" />
            <Setter Property="BorderBrush" Value="#27456F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
        </Style>
        <Style Selector="TextBlock.badge-text">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#93C5FD" />
        </Style>
        <Style Selector="Border.commit-graph-line">
            <Setter Property="Width" Value="2" />
            <Setter Property="Background" Value="#334155" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
        <Style Selector="Border.commit-graph-node">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="#60A5FA" />
            <Setter Property="BorderBrush" Value="#DBEAFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style Selector="TextBlock.commit-refs">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="Border.diff-section">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Border.diff-section-header">
            <Setter Property="Background" Value="#111B2E" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="14,14,0,0" />
        </Style>
        <Style Selector="Border.diff-line">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#162033" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="Border.diff-content">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Border.diff-gutter">
            <Setter Property="Background" Value="#0D1420" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
        <Style Selector="TextBlock.diff-text">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Monaco, monospace" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style Selector="SelectableTextBlock.diff-text">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Monaco, monospace" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBlock.diff-header">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>
        <Style Selector="TextBlock.diff-subtitle">
            <Setter Property="FontFamily" Value="Cascadia Mono, Menlo, Consolas, Monaco, monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.diff-section-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#93C5FD" />
        </Style>
        <Style Selector="TextBlock.diff-line-number">
            <Setter Property="FontFamily" Value="Courier New, Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="ScrollViewer.list-scroll">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Application.Styles>
</Application>
