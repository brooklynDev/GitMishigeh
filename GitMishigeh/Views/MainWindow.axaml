<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitMishigeh.ViewModels"
        xmlns:model="using:GitMishigeh.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="GitMishigeh.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="GitMishigeh"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="760">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.app-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.nav-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.mono-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.list-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.subtle">
            <Setter Property="Foreground" Value="#8EA0BC" />
        </Style>
        <Style Selector="Border.sidebar-panel">
            <Setter Property="Background" Value="#0E1522" />
            <Setter Property="BorderBrush" Value="#1F2937" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="280,620,*" Margin="0">
        <Border Grid.Column="0"
                Classes="sidebar-panel"
                CornerRadius="0">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="app-title" Text="Workspace" />
                        <TextBlock Classes="subtle"
                                   Text="{Binding RepositoryPath}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="label" Text="Sections" />
                        <Border Background="#111C30"
                                BorderBrush="#23304A"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Classes="nav-title" Text="Working Copy" />
                                <Border Grid.Column="1" Classes="badge" VerticalAlignment="Center">
                                    <TextBlock Classes="badge-text" Text="{Binding ChangedFiles.Count}" />
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="label" Text="Recent Repositories" />
                        <ScrollViewer MaxHeight="240"
                                      Classes="list-scroll"
                                      IsVisible="{Binding HasRecentRepositories}">
                            <ListBox ItemsSource="{Binding RecentRepositories}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:RecentRepository">
                                        <Button Classes="subtle"
                                                Command="{Binding #RootWindow.DataContext.OpenRecentRepositoryCommand}"
                                                CommandParameter="{Binding .}"
                                                HorizontalContentAlignment="Stretch">
                                            <StackPanel Spacing="2">
                                                <TextBlock Classes="nav-title" Text="{Binding DisplayName}" />
                                                <TextBlock Classes="subtle"
                                                           Text="{Binding Path}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="label" Text="Branch" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="nav-title"
                                       Text="{Binding CurrentBranch}"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1"
                                    Background="#182335"
                                    CornerRadius="999"
                                    Padding="10,4"
                                    VerticalAlignment="Center">
                                <TextBlock Classes="label" Text="HEAD" />
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="label" Text="Recent Commits" />
                        <ScrollViewer MaxHeight="360" Classes="list-scroll">
                            <ListBox ItemsSource="{Binding RecentCommits}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:GitCommitItem">
                                        <Border Classes="list-item">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="badge-text"
                                                           Text="{Binding ShortHash}" />
                                                <TextBlock Classes="list-title"
                                                           Text="{Binding Message}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="12">
                    <Button Command="{Binding OpenRepoCommand}" Content="Open Repo" />
                    <Button Classes="subtle" Command="{Binding RefreshCommand}" Content="Refresh" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="16,14,12,14" RowSpacing="14">
            <Border Classes="card toolbar-shell">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBox Watermark="Commit Subject"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Classes="primary"
                            Command="{Binding CommitCommand}"
                            Content="Commit"
                            MinWidth="110" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                <Button Command="{Binding StageAllCommand}" Content="Stage All" />
                <Button Grid.Column="1"
                        Classes="subtle"
                        Command="{Binding UnstageAllCommand}"
                        Content="Unstage All" />
                <TextBlock Grid.Column="2"
                           Classes="muted"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="{Binding StatusSummary}" />
            </Grid>

            <Border Grid.Row="2" Classes="card" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Border BorderBrush="#23304A"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid ColumnDefinitions="72,*">
                            <TextBlock Classes="label" Text="Status" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Classes="label" Text="Filename" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Classes="list-scroll">
                        <ListBox ItemsSource="{Binding ChangedFiles}"
                                 SelectedItem="{Binding SelectedChangedFile, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="model:GitChangedFile">
                                    <Border Classes="list-item">
                                        <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <CheckBox Classes="file-selector"
                                                          IsChecked="{Binding IsSelected}"
                                                          Command="{Binding #RootWindow.DataContext.SelectChangedFileCommand}"
                                                          CommandParameter="{Binding .}" />
                                                <Border Classes="badge" VerticalAlignment="Center">
                                                    <TextBlock Classes="badge-text" Text="{Binding StatusCode}" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Classes="list-title"
                                                           Text="{Binding Path}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Classes="subtle" Text="{Binding StatusLabel}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2" Margin="12,0,0,0" MinHeight="0">
            <Border Classes="card"
                    CornerRadius="0"
                    BorderThickness="1,0,0,0"
                    MinHeight="0"
                    VerticalAlignment="Stretch">
                <DockPanel LastChildFill="True" MinHeight="0">
                    <Border DockPanel.Dock="Top"
                            BorderBrush="#23304A"
                            BorderThickness="0,0,0,1"
                            Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="mono-title"
                                       Text="{Binding SelectedDiffHeader}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Classes="muted"
                                       Text="{Binding OutputMessage}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer MinHeight="0"
                                  Background="#0B1220"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Visible">
                        <ItemsControl Margin="16" ItemsSource="{Binding DiffSections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="model:GitDiffSection">
                                    <Border Classes="diff-section">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Classes="diff-section-header">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Classes="badge"
                                                            Background="{Binding AccentBrush}"
                                                            BorderBrush="{Binding AccentBrush}"
                                                            Padding="10,4"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Classes="badge-text"
                                                                   Foreground="#F8FAFC"
                                                                   Text="{Binding KindLabel}" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Classes="diff-header"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Classes="muted diff-subtitle"
                                                                   IsVisible="{Binding HasSubtitle}"
                                                                   Text="{Binding Subtitle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Lines}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="model:GitDiffLine">
                                                        <Border Classes="diff-line"
                                                                Background="{Binding Background}">
                                                            <Grid ColumnDefinitions="56,56,*"
                                                                  HorizontalAlignment="Stretch">
                                                                <Border Classes="diff-gutter">
                                                                    <TextBlock Classes="diff-line-number"
                                                                               Text="{Binding LeftLineNumber}" />
                                                                </Border>
                                                                <Border Grid.Column="1" Classes="diff-gutter">
                                                                    <TextBlock Classes="diff-line-number"
                                                                               Text="{Binding RightLineNumber}" />
                                                                </Border>
                                                                <Border Grid.Column="2" Classes="diff-content">
                                                                    <TextBlock Classes="diff-text"
                                                                               Foreground="{Binding Foreground}"
                                                                               Text="{Binding Text}" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
