<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitMishigeh.ViewModels"
        xmlns:model="using:GitMishigeh.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="GitMishigeh.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Icon="/Assets/git-mishigeh.ico"
        Title="GitMishigeh"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="760">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.app-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.nav-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.mono-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.list-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#E5EAF3" />
        </Style>
        <Style Selector="TextBlock.subtle">
            <Setter Property="Foreground" Value="#A0AEC3" />
        </Style>
        <Style Selector="Border.sidebar-panel">
            <Setter Property="Background" Value="#0E1620" />
            <Setter Property="BorderBrush" Value="#2A374B" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TextBlock.sidebar-heading">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#9AA7BC" />
        </Style>
        <Style Selector="Border.sidebar-nav-item">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.sidebar-nav-item.active">
            <Setter Property="Background" Value="#355E93" />
        </Style>
        <Style Selector="TextBlock.sidebar-nav-icon">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#7FC7D9" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.sidebar-nav-item.active TextBlock.sidebar-nav-icon">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="TextBlock.sidebar-nav-text">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#D8E0EC" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.sidebar-nav-item.active TextBlock.sidebar-nav-text">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.sidebar-row">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBlock.sidebar-row-text">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#D6DEEA" />
        </Style>
        <Style Selector="Border.sidebar-head-pill">
            <Setter Property="Background" Value="#2E3A4A" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,2" />
        </Style>
        <Style Selector="TextBlock.sidebar-head-pill-text">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D6DEEA" />
        </Style>
        <Style Selector="Border.top-strip">
            <Setter Property="Background" Value="#1B2330" />
            <Setter Property="BorderBrush" Value="#111722" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style Selector="TextBlock.top-strip-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.top-strip-value">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
        <Style Selector="TextBlock.top-strip-meta">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#B7C4D8" />
        </Style>
        <Style Selector="ComboBox.top-strip-combo">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="Border.modal-backdrop">
            <Setter Property="Background" Value="#AA020617" />
        </Style>
        <Style Selector="Border.modal-card">
            <Setter Property="Background" Value="#151C27" />
            <Setter Property="BorderBrush" Value="#38465D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="0">
        <Grid ColumnDefinitions="1.35*,1.25*,1.3*,*" Grid.Row="0">
            <Border Classes="top-strip">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Text="▣"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Foreground="#F8FAFC" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Classes="top-strip-title" Text="Current Repository" />
                        <ComboBox Classes="top-strip-combo"
                                  ItemsSource="{Binding RecentRepositories}"
                                  SelectedItem="{Binding SelectedRecentRepository, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="model:RecentRepository">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="top-strip-value" Text="{Binding DisplayName}" />
                                        <TextBlock Classes="top-strip-meta"
                                                   Text="{Binding Path}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.SelectionBoxItemTemplate>
                                <DataTemplate x:DataType="model:RecentRepository">
                                    <TextBlock Classes="top-strip-value"
                                               Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ComboBox.SelectionBoxItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="top-strip">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Text="⑂"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Foreground="#F8FAFC" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Classes="top-strip-title" Text="Current Branch" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBlock Classes="top-strip-value"
                                       Text="{Binding CurrentBranch}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding OpenBranchManagerCommand}"
                                    Content="Manage" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Classes="subtle"
                    Command="{Binding FetchCommand}"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                <Border Classes="top-strip"
                        BorderThickness="0,0,1,1">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <TextBlock Text="↻"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Foreground="#F8FAFC" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Classes="top-strip-title" Text="Fetch origin" />
                            <TextBlock Classes="top-strip-meta" Text="{Binding FetchStatusText}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>

            <Border Grid.Column="3"
                    Classes="top-strip"
                    BorderThickness="0,0,0,1">
                <StackPanel Spacing="2"
                            VerticalAlignment="Center">
                    <TextBlock Classes="top-strip-title" Text="Status" />
                    <TextBlock Classes="top-strip-meta"
                               Text="{Binding OutputMessage}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding NavigationPaneWidth}" MinWidth="180" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="{Binding FilePaneWidth}" MinWidth="320" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" MinWidth="360" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                Classes="sidebar-panel">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border BorderBrush="#1F2937"
                        Background="#111A25"
                        BorderThickness="0,0,0,1"
                        Padding="12,12,12,10">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="sidebar-heading" Text="WORKSPACE" />
                        <TextBlock Classes="nav-title"
                                   Text="{Binding CurrentBranch}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Classes="subtle"
                                   FontSize="11"
                                   Text="{Binding RepositoryPath}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Classes="list-scroll">
                    <StackPanel Margin="10,10,10,12" Spacing="12">
                        <StackPanel Spacing="2">
                            <Button Command="{Binding ShowWorkingTreeCommand}"
                                    IsVisible="{Binding IsWorkingCopyMode}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch">
                                <Border Classes="sidebar-nav-item active">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                        <TextBlock Classes="sidebar-nav-icon" Text="▭" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="sidebar-nav-text"
                                                   Text="Working Copy" />
                                        <Border Grid.Column="2" Classes="badge" VerticalAlignment="Center">
                                            <TextBlock Classes="badge-text"
                                                       Foreground="#FFFFFF"
                                                       Text="{Binding ChangedFiles.Count}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button Command="{Binding ShowWorkingTreeCommand}"
                                    IsVisible="{Binding IsShowingCommitHistory}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch">
                                <Border Classes="sidebar-nav-item">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                        <TextBlock Classes="sidebar-nav-icon" Text="▭" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="sidebar-nav-text"
                                                   Text="Working Copy" />
                                        <Border Grid.Column="2" Classes="badge" VerticalAlignment="Center">
                                            <TextBlock Classes="badge-text" Text="{Binding ChangedFiles.Count}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button Command="{Binding ShowHistoryCommand}"
                                    IsVisible="{Binding IsShowingCommitHistory}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch">
                                <Border Classes="sidebar-nav-item active">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="sidebar-nav-icon" Text="◔" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="sidebar-nav-text"
                                                   Text="History" />
                                    </Grid>
                                </Border>
                            </Button>

                            <Button Command="{Binding ShowHistoryCommand}"
                                    IsVisible="{Binding IsWorkingCopyMode}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalContentAlignment="Stretch">
                                <Border Classes="sidebar-nav-item">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <TextBlock Classes="sidebar-nav-icon" Text="◔" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="sidebar-nav-text"
                                                   Text="History" />
                                    </Grid>
                                </Border>
                            </Button>
                        </StackPanel>

                        <Border Height="1"
                                Background="#243042"
                                Margin="2,4" />

                        <StackPanel Spacing="6"
                                    IsVisible="{Binding IsShowingCommitHistory}">
                            <TextBlock Classes="sidebar-heading" Text="Recent Commits" />
                            <ListBox ItemsSource="{Binding RecentCommits}"
                                     SelectedItem="{Binding SelectedCommit, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:GitCommitItem">
                                        <Border Classes="list-item">
                                            <Grid ColumnDefinitions="18,*" ColumnSpacing="8">
                                                <Grid Width="18">
                                                    <Border Classes="commit-graph-line"
                                                            IsVisible="{Binding ShowConnector}" />
                                                    <Border Classes="commit-graph-node" />
                                                </Grid>

                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Classes="badge-text"
                                                                   Text="{Binding ShortHash}" />
                                                        <TextBlock Classes="muted commit-refs"
                                                                   IsVisible="{Binding HasRefs}"
                                                                   Text="{Binding Refs}" />
                                                    </StackPanel>
                                                    <TextBlock Classes="list-title"
                                                               Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               FontSize="12" />
                                                    <TextBlock Classes="subtle"
                                                               FontSize="11"
                                                               Text="{Binding AuthorName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Spacing="6"
                                    IsVisible="{Binding IsWorkingCopyMode}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Classes="sidebar-heading" Text="Branches" />
                                <Button Grid.Column="1"
                                        Command="{Binding OpenBranchManagerCommand}"
                                        Content="Manage" />
                            </Grid>
                            <ListBox ItemsSource="{Binding Branches}"
                                     SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                                     DoubleTapped="BranchListBox_OnDoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:GitBranchItem">
                                        <Border Classes="sidebar-row">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                <TextBlock Classes="sidebar-nav-icon" Text="⑂" FontSize="14" />
                                                <TextBlock Grid.Column="1"
                                                           Classes="sidebar-row-text"
                                                           Text="{Binding Name}" />
                                                <Border Grid.Column="2"
                                                        Classes="sidebar-head-pill"
                                                        IsVisible="{Binding IsCurrent}">
                                                    <TextBlock Classes="sidebar-head-pill-text"
                                                               Text="{Binding HeadLabel}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Spacing="6"
                                    IsVisible="{Binding IsWorkingCopyMode}">
                            <TextBlock Classes="sidebar-heading" Text="Remotes" />
                            <ItemsControl ItemsSource="{Binding Remotes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:GitRemoteItem">
                                        <Border Classes="sidebar-row">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                <TextBlock Classes="sidebar-nav-icon" Text="⌁" FontSize="14" />
                                                <TextBlock Grid.Column="1"
                                                           Classes="sidebar-row-text"
                                                           Text="{Binding Name}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderBrush="#2A374B"
                        Background="#101721"
                        BorderThickness="0,1,0,0"
                        Padding="10">
                    <Button Command="{Binding OpenRepoCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Content="Open Repo" />
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Cursor="SizeWestEast"
                      Background="Transparent" />

        <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*" Margin="16,14,12,14" RowSpacing="14">
            <Border Classes="card toolbar-shell">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBox Watermark="Commit Subject"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Classes="primary"
                            Command="{Binding CommitCommand}"
                            Content="Commit"
                            MinWidth="110" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="10">
                <Button Command="{Binding PullCommand}" Content="Pull" />
                <Button Grid.Column="1"
                        Command="{Binding PushCommand}"
                        Content="{Binding PushButtonText}" />
                <Button Grid.Column="2"
                        Command="{Binding StageAllCommand}"
                        Content="Stage All" />
                <Button Grid.Column="3"
                        Classes="subtle"
                        Command="{Binding UnstageAllCommand}"
                        Content="Unstage All" />
                <TextBlock Grid.Column="4"
                           Classes="muted"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="{Binding StatusSummary}" />
            </Grid>

            <Border Grid.Row="2" Classes="card" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Border BorderBrush="#23304A"
                            Background="#172130"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid ColumnDefinitions="72,*">
                            <TextBlock Classes="label" Text="{Binding FilePaneStatusHeader}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Classes="label" Text="{Binding FilePaneHeaderText}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Classes="list-scroll">
                        <ListBox ItemsSource="{Binding VisibleFiles}"
                                 SelectedItem="{Binding SelectedFileEntry, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="model:GitChangedFile">
                                    <Border Classes="list-item">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{Binding StageMenuText}"
                                                          IsEnabled="{Binding CanToggleStage}"
                                                          Command="{Binding #RootWindow.DataContext.ToggleStageFileCommand}"
                                                          CommandParameter="{Binding .}" />
                                                <MenuItem Header="{Binding DiscardMenuText}"
                                                          IsEnabled="{Binding CanDiscardChanges}"
                                                          Command="{Binding #RootWindow.DataContext.DiscardFileCommand}"
                                                          CommandParameter="{Binding .}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ColumnDefinitions="72,*" ColumnSpacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <CheckBox Classes="file-selector"
                                                          IsVisible="{Binding CanToggleStage}"
                                                          IsChecked="{Binding IsStaged, Mode=OneWay}"
                                                          Command="{Binding #RootWindow.DataContext.ToggleStageFileCommand}"
                                                          CommandParameter="{Binding .}" />
                                                <Border Classes="badge" VerticalAlignment="Center">
                                                    <TextBlock Classes="badge-text" Text="{Binding StatusCode}" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Classes="list-title"
                                                           Text="{Binding Path}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Classes="subtle" Text="{Binding StatusLabel}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="3"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Cursor="SizeWestEast"
                      Background="Transparent" />

        <Grid Grid.Column="4" Margin="12,0,0,0" MinHeight="0">
            <Border Classes="card"
                    CornerRadius="0"
                    BorderThickness="1,0,0,0"
                    MinHeight="0"
                    VerticalAlignment="Stretch">
                <DockPanel LastChildFill="True" MinHeight="0">
                    <Border DockPanel.Dock="Top"
                            BorderBrush="#23304A"
                            BorderThickness="0,0,0,1"
                            Padding="20,16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="mono-title"
                                       Text="{Binding SelectedDiffHeader}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Classes="muted"
                                       Text="{Binding OutputMessage}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer MinHeight="0"
                                  Background="#0D141E"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Visible">
                        <ItemsControl Margin="16" ItemsSource="{Binding DiffSections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="model:GitDiffSection">
                                    <Border Classes="diff-section">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Classes="diff-section-header">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <Border Classes="badge"
                                                            Background="{Binding AccentBrush}"
                                                            BorderBrush="{Binding AccentBrush}"
                                                            Padding="10,4"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Classes="badge-text"
                                                                   Foreground="#F8FAFC"
                                                                   Text="{Binding KindLabel}" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Classes="diff-header"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Classes="muted diff-subtitle"
                                                                   IsVisible="{Binding HasSubtitle}"
                                                                   Text="{Binding Subtitle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Lines}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="model:GitDiffLine">
                                                        <Border Classes="diff-line"
                                                                Background="{Binding Background}">
                                                            <Grid ColumnDefinitions="56,56,*"
                                                                  HorizontalAlignment="Stretch">
                                                                <Border Classes="diff-gutter">
                                                                    <TextBlock Classes="diff-line-number"
                                                                               Text="{Binding LeftLineNumber}" />
                                                                </Border>
                                                                <Border Grid.Column="1" Classes="diff-gutter">
                                                                    <TextBlock Classes="diff-line-number"
                                                                               Text="{Binding RightLineNumber}" />
                                                                </Border>
                                                                <Border Grid.Column="2" Classes="diff-content">
                                                                    <TextBlock Classes="diff-text"
                                                                               Foreground="{Binding Foreground}"
                                                                               Text="{Binding Text}" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
        </Grid>

        <Border Grid.RowSpan="2"
                Classes="modal-backdrop"
                IsVisible="{Binding IsBranchManagerOpen}">
            <Grid>
                <Border Classes="modal-card"
                        Width="640"
                        MaxHeight="720"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="app-title" Text="Branch Manager" />
                                <TextBlock Classes="subtle"
                                           Text="Create, switch, and clean up branches from one place." />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="subtle"
                                    Command="{Binding CloseBranchManagerCommand}"
                                    Content="Close" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Watermark="New branch name"
                                     Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Command="{Binding CreateBranchCommand}"
                                    Content="Create Branch"
                                    MinWidth="120" />
                        </Grid>

                        <Border Grid.Row="2"
                                Classes="card"
                                Padding="0"
                                MinHeight="280">
                            <Grid RowDefinitions="Auto,*">
                                <Border BorderBrush="#23304A"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                        <TextBlock Classes="label" Text="Branch" />
                                        <TextBlock Grid.Column="1" Classes="label" Text="State" />
                                        <TextBlock Grid.Column="2" Classes="label" Text="Actions" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" Classes="list-scroll">
                                    <ListBox ItemsSource="{Binding Branches}"
                                             SelectedItem="{Binding SelectedBranch, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="model:GitBranchItem">
                                                <Border Classes="list-item">
                                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Classes="list-title"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Classes="subtle"
                                                                       Text="Current branch"
                                                                       IsVisible="{Binding IsCurrent}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1"
                                                                Classes="sidebar-head-pill"
                                                                IsVisible="{Binding IsCurrent}"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Classes="sidebar-head-pill-text"
                                                                       Text="{Binding HeadLabel}" />
                                                        </Border>
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <Button Command="{Binding #RootWindow.DataContext.CheckoutBranchCommand}"
                                                                    CommandParameter="{Binding .}"
                                                                    Content="Switch"
                                                                    IsVisible="{Binding CanCheckout}" />
                                                            <Button Classes="subtle"
                                                                    Command="{Binding #RootWindow.DataContext.DeleteBranchCommand}"
                                                                    CommandParameter="{Binding .}"
                                                                    Content="Delete"
                                                                    IsVisible="{Binding CanDelete}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Classes="subtle"
                                       VerticalAlignment="Center"
                                       Text="{Binding CurrentBranch, StringFormat='Current branch: {0}'}" />
                            <Button Grid.Column="1"
                                    Command="{Binding CheckoutSelectedBranchCommand}"
                                    Content="Switch Selected" />
                            <Button Grid.Column="2"
                                    Classes="subtle"
                                    Command="{Binding CloseBranchManagerCommand}"
                                    Content="Done" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>

</Window>
